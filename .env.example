# Copia este archivo como .env y completa con tus propios valores.
# Nunca subas el archivo .env real al repositorio.

# Django
SECRET_KEY=cambia-esto-por-una-clave-secreta-generada
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (MySQL)
DB_NAME=trs_maquinaria
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_HOST=localhost
DB_PORT=3306

# Cloudinary (almacenamiento de imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Solo producción (cPanel/Passenger), opcional en local
STATIC_ROOT=
TRS_PROJECT_PATH=
TRS_VENV_ACTIVATE_PATH=
